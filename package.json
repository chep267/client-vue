{
    "name": "chep-client-vue",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "test": "vitest",
        "dev": "vite",
        "dev-server": "cd ../express-server && pnpm dev",
        "type-check": "vue-tsc -b",
        "build": "rimraf dist && vue-tsc -b && vite build",
        "preview": "vite preview",
        "lint": "eslint . --fix",
        "format": "prettier --write .",
        "update-all": "rm -rf node_modules && pnpm up --latest",
        "deploy": "pnpm build && gh-pages -d dist",
        "analyze": "open dist/stats.html",
        "check-code": "node script/check-coding-rules.ts"
    },
    "dependencies": {
        "@mdi/js": "^7.4.47",
        "@popperjs/core": "^2.11.8",
        "@tanstack/vue-query": "^5.96.2",
        "@tsparticles/slim": "^3.9.1",
        "@tsparticles/vue3": "^3.0.1",
        "@vueuse/core": "^14.2.1",
        "axios": "^1.14.0",
        "clsx": "^2.1.1",
        "dayjs": "^1.11.20",
        "js-cookie": "^3.0.5",
        "pinia": "^3.0.4",
        "tailwindcss": "^4.2.2",
        "v-calendar": "^3.1.2",
        "vee-validate": "^4.15.1",
        "vue": "^3.5.32",
        "vue-i18n": "11.3.1",
        "vue-router": "^5.0.4",
        "vuetify": "^4.0.5"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.2.2",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/vue": "^8.1.0",
        "@tsconfig/node24": "^24.0.4",
        "@types/js-cookie": "^3.0.6",
        "@types/node": "^25.5.2",
        "@vitejs/plugin-basic-ssl": "^2.3.0",
        "@vitejs/plugin-vue": "^6.0.5",
        "@vitest/ui": "^4.1.2",
        "@vue/eslint-config-prettier": "^10.2.0",
        "@vue/eslint-config-typescript": "^14.7.0",
        "@vue/test-utils": "^2.4.6",
        "@vue/tsconfig": "^0.9.1",
        "eslint": "^10.2.0",
        "eslint-plugin-vue": "^10.8.0",
        "jsdom": "^29.0.2",
        "prettier": "^3.8.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "rimraf": "^6.1.3",
        "rollup-plugin-visualizer": "^7.0.1",
        "sass-embedded": "^1.99.0",
        "tw-animate-css": "^1.4.0",
        "typescript": "^6.0.2",
        "vite": "^8.0.5",
